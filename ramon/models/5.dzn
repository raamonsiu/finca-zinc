    1,1, 1,2, 2,1, 3,1, 4,1, 0,0,
    1,1, 1,2, 1,3, 1,4, 2,1, 0,0,
    1,1, 1,2, 1,3, 1,4, 2,4, 0,0,
    
    % Type 4 
    1,1, 2,1, 3,1, 3,2, 4,2, 0,0,
    1,2, 2,2, 3,1, 3,2, 4,1, 0,0,
    1,3, 1,4, 2,1, 2,2, 2,3, 0,0,
    1,1, 1,2, 2,2, 2,3, 2,4, 0,0,
    1,1, 2,1, 2,2, 3,2, 4,2, 0,0,
    1,2, 2,1, 2,2, 3,1, 4,1, 0,0,
    1,2, 1,3, 1,4, 2,1, 2,2, 0,0,
    1,1, 1,2, 1,3, 2,3, 3,4, 0,0,
    
