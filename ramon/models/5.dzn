    1,1, 1,2, 2,1, 3,1, 3,2, 0,0,
    
    % Type 8: long L shape with 4 orientations
    1,1, 2,1, 3,1, 3,2, 3,3, 0,0,
    1,3, 2,3, 3,1, 3,2, 3,3, 0,0,
    1,1, 1,2, 1,3, 2,1, 3,1, 0,0,
    1,1, 1,2, 1,3, 2,3, 3,3, 0,0,
    
